  inst COMPOSITE_SWITCHBOX back_cmd_gate_sw : a="Control Commands Type 3 from Back", switch=back_master_gate_out -> out=back_cmd_gate_sw_out

  # --- Numeric channels 1-3 (summed from both sides) ---
