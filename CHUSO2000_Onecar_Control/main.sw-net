  inst NOT front_inactive_not : a=front_active_flag_read_out -> out=front_inactive_not_out
  inst AND front_master_gate : a=front_active_flag_read_out, b=back_inactive_not_out -> out=front_master_gate_out
  inst AND back_master_gate : a=back_active_flag_read_out, b=front_inactive_not_out -> out=back_master_gate_out
  inst OR either_active_or : a=front_active_flag_read_out, b=back_active_flag_read_out -> out=either_active_or_out
