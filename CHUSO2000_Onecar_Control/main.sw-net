  # --- Simple IF RX channel swap ---
  inst COMPOSITE_READ_NUMBER simif_rx_ch5_num_read (channel=5) : composite="Simple IF RX" -> out=simif_rx_ch5_num_read_out
  inst COMPOSITE_READ_NUMBER simif_rx_ch4_num_read (channel=4) : composite="Simple IF RX" -> out=simif_rx_ch4_num_read_out
