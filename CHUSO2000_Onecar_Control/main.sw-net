  inst AND ch32_master_and : a=ch32_bool_or_out, b=either_master_or_out -> out=ch32_master_and_out

  # --- Output composite ---
  inst COMPOSITE_WRITE_NUMBER num_cmd_write (count=7, offset=1) : in1=ch1_num_sum_out, in2=ch2_num_sum_out, in3=ch3_num_sum_out, in4=front_ch4_num_read_out, in5=front_ch5_num_read_out, in6=ch6_decoded_read_out, in7=packed_bits_num_out -> out=num_cmd_write_out
