  inst OR ch30_28_crossed_or : a=front_ch30_bool_read_out, b=back_ch28_bool_read_out -> out=ch30_28_crossed_or_out

  # --- Boolean channels 31-32 ---
  inst COMPOSITE_READ_BOOLEAN front_ch31_bool_read (channel=31) : composite="Control Commands Type 3 from Front" -> out=front_ch31_bool_read_out
  inst COMPOSITE_READ_BOOLEAN back_ch31_bool_read (channel=31) : composite="Control Commands Type 3 from Back" -> out=back_ch31_bool_read_out
