module main
  port in "Control Commands Type 3 from Front" : composite
  port in "Control Commands Type 3 from Back" : composite
  port out "Control Commands Type 3" : composite
  port in "Simple IF RX" : composite
  port out "Simple IF RX inverted" : composite

  # --- Active detection and master gate ---
  inst COMPOSITE_READ_BOOLEAN back_active_flag_read (channel=6) : composite="Control Commands Type 3 from Back" -> out=back_active_flag_read_out
  inst COMPOSITE_READ_BOOLEAN front_active_flag_read (channel=6) : composite="Control Commands Type 3 from Front" -> out=front_active_flag_read_out
